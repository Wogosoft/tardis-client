{
  "version": "2.2.4",
  "name": "@wogo/tardis-client",
  "license": "GPL-3.0-only",
  "exports": {
    ".": "./mod.ts",
    "./errors": "./errors.ts"
  },
  "tasks": {
    "test": "deno test mod.spec.ts",
    "sandbox": "deno run -A ./sandbox.ts"
  },
  "publish": {
    "include": ["./gen/wogo/tardis", "./gen/grpc/health", "./mod.ts", "./errors.ts"]
  },
  "lint": {
    "rules": {
      "exclude": ["ban-types", "ban-ts-comment"]
    }
  },
  "imports": {
    "@effect": "npm:effect@3.19.3",
    "@tardis/authenticator/": "./gen/wogo/tardis/authenticator/v1/",
    "@tardis/common/": "./gen/wogo/tardis/common/v1/",
    "@tardis/management/": "./gen/wogo/tardis/management/v1/",
    "@tardis/parking/": "./gen/wogo/tardis/parking/v1/",
    "@tardis/health/": "./gen/grpc/health/v1/",
    "@bufbuild/protobuf": "npm:@bufbuild/protobuf@^2.6.0",
    "@connectrpc/connect" : "npm:@connectrpc/connect@2.0.2",
    "@connectrpc/connect-node": "npm:@connectrpc/connect-node@2.0.2"
  },
  "nodeModulesDir": "auto"
}
